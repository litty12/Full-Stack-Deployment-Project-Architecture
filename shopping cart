let cart =
  JSON.parse(
    localStorage.getItem("cart")
  ) || [];

export function addToCart(product) {

  cart.push(product);

  localStorage.setItem(
    "cart",
    JSON.stringify(cart)
  );
}

export function getCart() {
  return cart;
}

export function removeFromCart(id) {

  cart = cart.filter(
    item => item.id !== id
  );

  localStorage.setItem(
    "cart",
    JSON.stringify(cart)
  );
}
